# Copy to .env and adjust values for local development.
# The service reads all config from environment variables — no file parsing.
# Usage: source .env && go run ./cmd/server

# ── Service ──────────────────────────────────────────────────────────────────
PORT=8080
OTEL_SERVICE_NAME=go-lgtmp
OTEL_SERVICE_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=debug

# ── OpenTelemetry (Alloy / OTel Collector) ───────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true

# ── Pyroscope ─────────────────────────────────────────────────────────────────
PYROSCOPE_SERVER_ADDRESS=http://localhost:4040

# ── PostgreSQL (optional — enables /db/* endpoints) ───────────────────────────
# docker compose up -d postgres
DATABASE_DSN=postgres://demo:demo@localhost:5432/demo?sslmode=disable

# ── Redis (optional — enables /cache/* endpoints) ────────────────────────────
# docker compose up -d redis
REDIS_ADDR=localhost:6379
